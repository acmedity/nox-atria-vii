<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ entry.name }} — {{ site.subtitle }}</title>
  <link rel="stylesheet" href="/assets/css/site.css">
</head>
<body>
  {% include "partials/site-header.njk" %}
  <div class="layout layout--entry">
    <aside class="sidebar">
      {% include "partials/site-toc.njk" %}
    </aside>
    <main class="content">
      <div class="content-inner">
        {{ content | safe }}
      </div>
    </main>
    <aside class="rail">
      {% include "partials/field-card.njk" %}
      {% if entry.marginalia and entry.marginalia.length %}
        <div class="rail-marginalia" id="marginalia">
          <p class="subhead">Marginalia</p>
          {% for block in entry.marginalia %}
            <pre class="marginalia" data-anchor="sec-{{ block.target }}">{{ block.text }}</pre>
          {% endfor %}
        </div>
      {% endif %}
    </aside>
  </div>
  <footer class="site-footer">
    &ldquo;<i>{{ site.motto }}</i> &middot; {{ site.motto_gloss }}&rdquo; &mdash; the Nox Atria Survey
  </footer>
</body>
</html>
