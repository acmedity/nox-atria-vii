<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {{ site.subtitle }}{% else %}{{ site.title }}{% endif %}</title>
  <link rel="stylesheet" href="/assets/css/site.css">
</head>
<body>
  {% include "partials/site-header.njk" %}
  <div class="layout">
    <aside class="sidebar">
      {% include "partials/site-toc.njk" %}
    </aside>
    <main class="content">
      <div class="content-inner">
        {{ content | safe }}
      </div>
    </main>
  </div>
  <footer class="site-footer">
    &ldquo;<i>{{ site.motto }}</i> &middot; {{ site.motto_gloss }}&rdquo; &mdash; the Nox Atria Survey
  </footer>
</body>
</html>
