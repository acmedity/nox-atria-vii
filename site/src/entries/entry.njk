---
pagination:
  data: entries
  size: 1
  alias: entry
permalink: "/entries/{{ entry.name }}/"
layout: layouts/entry.njk
eleventyComputed:
  title: "{{ entry.name }}"
---
<article class="entry">
<header class="entry-header">
  <h1 class="entry-title">{{ entry.name }}</h1>
  <p class="entry-binomial"><em lang="la">{{ entry.binomial }}</em></p>
  <p class="entry-meta">
    First observed {{ entry.first_observed }}
    &middot; {{ entry.displayObserver }}
  </p>
</header>

{% for section in entry.sections %}
  {% if section.heading == "Plates" %}
    <section id="sec-{{ section.slug }}" class="entry-section">
      <h2 class="subhead">{{ section.heading }}</h2>
      {% if section.html %}<div class="entry-prose">{{ section.html | safe }}</div>{% endif %}
      {% if entry.plateFiles and entry.plateFiles.length %}
        <div class="entry-prose entry-plate-files">
          {% for plate in entry.plateFiles %}
            <figure class="entry-ascii-plate">
              <figcaption>
                <a href="{{ plate.url }}">Plate {{ plate.roman }} — {{ plate.filename }}</a>
              </figcaption>
              {% if plate.missing %}
                <p><strong>Missing plate file:</strong> {{ plate.filename }}</p>
              {% else %}
                <pre><code>{{ plate.content }}</code></pre>
              {% endif %}
            </figure>
          {% endfor %}
        </div>
      {% endif %}
    </section>
  {% endif %}
{% endfor %}

{% for section in entry.sections %}
  {% if section.heading != "Plates" %}
    <section id="sec-{{ section.slug }}" class="entry-section">
      <h2 class="subhead">{{ section.heading }}</h2>
      <div class="entry-prose">{{ section.html | safe }}</div>
    </section>
  {% endif %}
{% endfor %}
</article>
